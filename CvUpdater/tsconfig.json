{
  "compilerOptions": {
    "target": "ES2020",
"module": "Node16",
"moduleResolution": "node16",
    "strict": true,
    "sourceMap": false,
    "declaration": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts"
  ]
}
